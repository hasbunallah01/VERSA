# --- Creative engine (required) ---
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini)
# VERSA_MODEL=gpt-4o-mini

# --- Wallet data (recommended: richer portraits) ---
ETHERSCAN_API_KEY=
# Optional RPC fallback override (default https://eth.llamarpc.com)
# ETH_RPC_URL=

# --- x402 payments ---
# Keep false until the facilitator details are confirmed; true for paid mode.
X402_ENABLED=false
X402_PAY_TO=0x5dee51725a9503fa43e09caec51de6ff20918baa
X402_AMOUNT=50000            # $0.05 in 6-decimal units
X402_NETWORK=eip155:196      # X Layer
X402_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736   # USDT0 on X Layer (confirmed)
X402_ASSET_NAME=USDT0
# Facilitator base defaults to https://web3.okx.com/api/v6/pay/x402 (confirmed
# from OKX's Onchain OS payment API docs) — only set this to override.
# Facilitator base defaults to https://web3.okx.com (confirmed from the
# official @okxweb3/x402-core SDK) — only set this to override.
X402_FACILITATOR_BASE=
# Required: OKX Onchain OS API credentials for facilitator auth (HMAC-SHA256
# request signing, matching OKX's standard REST API auth scheme).
X402_API_KEY=
X402_SECRET_KEY=
X402_PASSPHRASE=
X402_MAX_TIMEOUT_SECS=300

# --- Alternative LLM provider (optional) ---
# Point the creative engine at any OpenAI-compatible API instead of OpenAI.
# Example: FreeModel (free tier) — set OPENAI_API_KEY to your FreeModel key.
# OPENAI_BASE_URL=https://api.freemodel.dev/v1
# VERSA_MODEL=gpt-4o-mini
